# =============================================================================
# E-Commerce Platform - Environment Variables
# =============================================================================
# Copy this file to .env.local for local development
# All values shown here are examples - replace with your actual configuration
# =============================================================================

# =============================================================================
# Core Application
# =============================================================================

# Node environment: development | production | test
NODE_ENV=development

# Application port (optional, typically set by platform)
PORT=3000

# Base URL for the application (used for absolute URLs)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Optional: Google Search Console HTML tag verification (content value only)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# Optional: GA4 measurement ID (G-…) and/or GTM container (GTM-…). Use distinct values.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GOOGLE_TAG_MANAGER_ID=
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Vercel deployment URL (automatically set on Vercel)
VERCEL_URL=

# Skip environment validation (set to "true" only for debugging)
SKIP_ENV_VALIDATION=false

# Enable debug logs (set to "true" for verbose logging)
USE_DEBUG_LOGS=false

# =============================================================================
# Database (Neon Postgres)
# =============================================================================

# Neon Postgres connection string
# Format: postgres://user:password@host.neon.tech/database?sslmode=require
DATABASE_URL=postgres://user:password@host.neon.tech/database?sslmode=require

# =============================================================================
# Authentication (Better Auth)
# =============================================================================

# Better Auth secret (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=your_better_auth_secret_here

# Better Auth URL (must match your base URL)
BETTER_AUTH_URL=http://localhost:3000

# GitHub OAuth credentials
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# =============================================================================
# Email (Resend)
# =============================================================================

# Resend API key
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key

# From email address (must be verified in Resend)
RESEND_FROM_EMAIL=noreply@yourdomain.com

# =============================================================================
# File Storage (Vercel Blob)
# =============================================================================

# Vercel Blob read/write token
# Get from: https://vercel.com/dashboard/storage/blob
BLOB_READ_WRITE_TOKEN=vercel_blob_token_here

# =============================================================================
# Payment Processing (Razorpay)
# =============================================================================

# Razorpay API credentials
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_API_KEY=rzp_test_your_key_id
RAZORPAY_API_SECRET=your_razorpay_secret

# Razorpay Key ID (public - used by checkout.js)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id

# Optional: Connected account ID for marketplace payouts
RAZORPAY_ACCOUNT_ID=

# Razorpay Webhook Secret
# Get from: https://dashboard.razorpay.com/app/webhooks
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# =============================================================================
# Security (Arcjet)
# =============================================================================

# Arcjet API Key for rate limiting and bot protection
# Get from: https://app.arcjet.com/
# Code reads ARKJET_API_KEY; ARCJET_API_KEY is also accepted for compatibility.
ARKJET_API_KEY=ajkey_your_arcjet_key
# ARCJET_API_KEY=ajkey_your_arcjet_key

# =============================================================================
# Notes
# =============================================================================
# 1. Never commit real secrets to version control
# 2. Use Vercel Environment Variables for production deployments
# 3. All NEXT_PUBLIC_ variables are exposed to the browser
# 4. Server-only variables should never have NEXT_PUBLIC_ prefix
# =============================================================================
